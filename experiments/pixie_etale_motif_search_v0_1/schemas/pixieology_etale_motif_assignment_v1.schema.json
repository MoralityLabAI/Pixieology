    "semantic_group_id": {"type": "string"},
    "family": {"type": "string"},
    "variant": {"type": "string"},
    "split": {"enum": ["discovery", "confirmation", "transfer"]},
    "motif_id": {"type": ["string", "null"]},
    "status": {"enum": ["assigned", "unassigned"]},
    "distance": {"type": ["number", "null"]},
    "assignment_radius": {"type": ["number", "null"]},
    "all_distances": {"type": "object", "additionalProperties": {"type": "number"}}
  },
  "additionalProperties": false
}
