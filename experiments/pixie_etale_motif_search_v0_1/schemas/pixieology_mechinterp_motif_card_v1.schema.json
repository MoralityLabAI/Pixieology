{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixieology_mechinterp_motif_card_v1.schema.json",
  "type": "object",
  "required": ["schema", "motif_id", "evidence_class", "medoid_input_id", "recognition", "prohibited_inference", "gates"],
  "properties": {
    "schema": {"const": "pixieology_mechinterp_motif_card_v1"},
    "motif_id": {"type": "string", "pattern": "^M[0-9]{2}$"},
    "human_label": {"type": ["string", "null"]},
    "evidence_class": {"type": "string"},
    "medoid_input_id": {"type": "string"},
    "recognition": {"type": "object"},
    "recommended_next_investigation": {"type": ["string", "null"]},
    "prohibited_inference": {"type": "string"},
    "gates": {"type": "object"}
  },
  "additionalProperties": false
}
